---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import heroImg from '../Images/dentista_01.png';
import clinicImg from '../Images/banner_02.webp';
import testimonialImg1 from '../Images/dentista_04.png';
import testimonialImg2 from '../Images/dentista_02.png';
import testimonialImg3 from '../Images/dentista_03.png';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.smartdentalcloud.com';

const features = [
  { icon: 'fa-users', title: 'Gestión de Pacientes', desc: 'Expedientes digitales completos con historial clínico, odontograma y documentos adjuntos.' },
  { icon: 'fa-calendar-days', title: 'Citas y Calendario', desc: 'Agenda inteligente con recordatorios automáticos por email y WhatsApp.' },
  { icon: 'fa-tooth', title: 'Odontograma Digital', desc: 'Registra tratamientos y hallazgos con un odontograma interactivo profesional.' },
  { icon: 'fa-file-invoice-dollar', title: 'Facturación y CFDI', desc: 'Timbra CFDIs directamente ante el SAT desde el sistema, sin software adicional.' },
  { icon: 'fa-boxes-stacked', title: 'Inventario', desc: 'Control de materiales con alertas de stock mínimo y trazabilidad de consumos.' },
  { icon: 'fa-chart-line', title: 'Reportes y Analíticas', desc: 'Dashboard con métricas de producción, ingresos y ocupación en tiempo real.' },
];

const stats = [
  { value: '500+', label: 'Consultorios activos', icon: 'fa-building' },
  { value: '50,000+', label: 'Pacientes gestionados', icon: 'fa-user-group' },
  { value: '99.9%', label: 'Disponibilidad', icon: 'fa-server' },
  { value: '4.9/5', label: 'Satisfacción', icon: 'fa-star' },
];

const logoWall = [
  { name: 'Dental Smile', initials: 'DS', color: '#2563eb' },
  { name: 'Oral Pro', initials: 'OP', color: '#059669' },
  { name: 'DentGroup', initials: 'DG', color: '#7c3aed' },
  { name: 'Boca Sana', initials: 'BS', color: '#d97706' },
  { name: 'OdontoPlus', initials: 'OP', color: '#0891b2' },
  { name: 'Clínica Bravo', initials: 'CB', color: '#dc2626' },
];

const journeyStages = [
  {
    icon: 'fa-magnet',
    color: '#2563eb',
    bg: '#dbeafe',
    title: 'Conecta con más pacientes',
    desc: 'Llena tu consultorio con pacientes nuevos y recurrentes a toda hora.',
    items: ['Agendamiento online 24/7', 'Recordatorios automáticos por WhatsApp', 'Confirmaciones de citas', 'Campañas por email'],
  },
  {
    icon: 'fa-heart-pulse',
    color: '#059669',
    bg: '#d1fae5',
    title: 'Brinda una experiencia de primer nivel',
    desc: 'La atención que diferenciará a tu consultorio del resto.',
    items: ['Historia clínica digital completa', 'Odontograma y periodontograma', 'Firma electrónica de consentimientos', 'Recetas y evoluciones digitales'],
  },
  {
    icon: 'fa-coins',
    color: '#d97706',
    bg: '#fef3c7',
    title: 'Aumenta tus ingresos',
    desc: 'Más facilidades para tus pacientes, más ingresos para ti.',
    items: ['Facturación y timbrado CFDI ante el SAT', 'Control de pagos y abonos', 'Presupuestos de tratamiento', 'Reportes de producción e ingresos'],
  },
  {
    icon: 'fa-gears',
    color: '#7c3aed',
    bg: '#ede9fe',
    title: 'Controla y optimiza la operación',
    desc: 'Ten control total de todo lo que sucede en tu consultorio.',
    items: ['Gestión de inventario con alertas', 'Control de caja y gastos', 'Dashboard con KPIs en tiempo real', 'Reportes exportables a Excel'],
  },
];

const steps = [
  { num: '1', icon: 'fa-user-plus', title: 'Crea tu cuenta', desc: 'Regístrate en menos de 2 minutos. Sin tarjeta de crédito.' },
  { num: '2', icon: 'fa-sliders', title: 'Configura tu consultorio', desc: 'Personaliza horarios, servicios, usuarios y catálogos.' },
  { num: '3', icon: 'fa-rocket', title: '¡Listo para atender!', desc: 'Comienza a gestionar pacientes, citas y facturación al instante.' },
];

const comparisonRows = [
  { feature: 'Acceso desde cualquier dispositivo', us: true, excel: false, legacy: 'partial' },
  { feature: 'Timbrado CFDI integrado (SAT)', us: true, excel: false, legacy: false },
  { feature: 'Recordatorios automáticos WhatsApp', us: true, excel: false, legacy: false },
  { feature: 'Actualizaciones automáticas', us: true, excel: true, legacy: false },
  { feature: 'Respaldo en la nube', us: true, excel: false, legacy: false },
  { feature: 'Odontograma digital', us: true, excel: false, legacy: 'partial' },
  { feature: 'Soporte técnico dedicado', us: true, excel: false, legacy: 'partial' },
  { feature: 'Sin instalación local', us: true, excel: true, legacy: false },
];

const testimonials = [
  {
    quote: 'Desde que implementamos SmartDental Cloud, la administración de mi consultorio se simplificó enormemente. Ahora puedo enfocarme en lo que realmente importa: mis pacientes.',
    name: 'C.D. Raúl Alejandro Bautista M.',
    role: 'Cirujano Dentista · Monterrey, N.L.',
    img: testimonialImg1,
  },
  {
    quote: 'El timbrado de CFDI directamente desde el sistema nos ahorró horas cada semana. Ya no necesitamos ningún otro software para facturar a nuestros pacientes.',
    name: 'C.D. Gabriela Torres R.',
    role: 'Directora · Clínica Oral Pro · Guadalajara, Jal.',
    img: testimonialImg2,
  },
  {
    quote: 'Los recordatorios automáticos de WhatsApp redujeron nuestras citas canceladas en un 40%. El retorno de inversión fue inmediato desde el primer mes.',
    name: 'C.D. Eduardo Mora S.',
    role: 'Ortodoncista · Puebla, Pue.',
    img: testimonialImg3,
  },
];

const faqs = [
  {
    q: '¿Necesito tarjeta de crédito para la prueba?',
    a: 'No. La prueba de 14 días es completamente gratis y no requiere tarjeta de crédito ni compromiso.',
  },
  {
    q: '¿El sistema cumple con los requisitos del SAT?',
    a: 'Sí. SmartDental Cloud genera y timbra CFDIs directamente ante el SAT. Compatible con CFDI 4.0.',
  },
  {
    q: '¿Puedo cambiar de plan después?',
    a: 'Sí, puedes subir o bajar de plan en cualquier momento desde tu panel de configuración.',
  },
  {
    q: '¿Qué pasa al terminar la prueba?',
    a: 'Si no activas un plan, tu cuenta se pausa pero tus datos se mantienen seguros por 90 días.',
  },
  {
    q: '¿Mis datos están seguros?',
    a: 'Sí. Usamos encriptación de grado bancario y nuestros servidores están en centros de datos certificados en México.',
  },
  {
    q: '¿Puedo migrar mis datos desde otro sistema?',
    a: 'Sí. Nuestro equipo de soporte te ayuda a importar tus pacientes y citas desde Excel o sistemas anteriores sin costo adicional.',
  },
];
---

<Layout
  title="Software Dental en la Nube para México"
  description="Gestiona tu consultorio dental con SmartDental Cloud: pacientes, citas, CFDI y facturación SAT, inventario y más. 14 días gratis, sin tarjeta."
>
  <Header />

  <!-- Hero — Split Layout with Dynamic Background -->
  <section class="hero hero-dynamic-bg">
    <!-- Hero Particles Canvas -->
    <canvas id="hero-particles-canvas" class="hero-particles-canvas"></canvas>
    
    <!-- Hero Orbs -->
    <div class="hero-orbs">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    
    <!-- Floating decorative elements -->
    <div class="hero-decorations">
      <div class="float-animation" style="position: absolute; top: 15%; left: 10%; width: 60px; height: 60px; background: linear-gradient(135deg, rgba(37,99,235,0.1), rgba(6,182,212,0.1)); border-radius: 50%; filter: blur(20px);"></div>
      <div class="float-animation-delayed" style="position: absolute; top: 60%; right: 15%; width: 80px; height: 80px; background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(6,182,212,0.1)); border-radius: 50%; filter: blur(25px);"></div>
      <div class="float-animation" style="position: absolute; bottom: 20%; left: 20%; width: 40px; height: 40px; background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(16,185,129,0.1)); border-radius: 50%; filter: blur(15px);"></div>
    </div>
    
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-badge" data-animate>
          <i class="fa-solid fa-sparkles"></i> 14 días gratis — sin tarjeta de crédito
        </span>
        <h1 data-animate data-delay="1">
          <span class="gradient-text-animated">El software dental</span> que tu consultorio merece
        </h1>
        <p data-animate data-delay="2">Gestiona pacientes, citas y factura CFDIs al SAT desde un solo lugar. Todo en la nube, 100% mexicano y fácil de usar.</p>
        <div class="hero-actions" data-animate data-delay="3">
          <a href={`${appUrl}/register`} class="btn btn-primary btn-lg btn-glow btn-shimmer btn-ripple">
            <i class="fa-solid fa-rocket"></i> Comenzar Prueba Gratis
          </a>
          <a href="/pricing" class="btn btn-outline btn-lg">Ver Precios</a>
        </div>
        <div class="hero-trust" data-animate data-delay="4">
          <span class="trust-item"><i class="fa-solid fa-shield-check"></i> Datos encriptados</span>
          <span class="trust-sep">·</span>
          <span class="trust-item"><i class="fa-solid fa-file-invoice-dollar"></i> CFDI 4.0 SAT</span>
          <span class="trust-sep">·</span>
          <span class="trust-item"><i class="fa-solid fa-server"></i> Servidores en México</span>
        </div>
      </div>
      <div class="hero-image float-animation" data-parallax="0.1">
        <Image src={heroImg} alt="Dentista usando SmartDental Cloud en tablet" width={520} quality={85} loading="eager" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- Stats Bar - Modern Interactive -->
  <section class="stats-bar-modern" id="stats">
    <div class="stats-bg-gradient"></div>
    <div class="container">
      <div class="stats-grid">
        {stats.map((s, i) => (
          <div class="stat-card" data-stat-index={String(i)} data-animate>
            <div class="stat-glow"></div>
            <div class="stat-icon-wrapper">
              <div class="stat-icon-ring"></div>
              <i class={`fa-solid ${s.icon}`}></i>
            </div>
            <div class="stat-content">
              <div class="stat-value-wrapper">
                <span class="stat-number" data-target={s.value.replace(/[^0-9]/g, '')} data-suffix={s.value.replace(/[0-9]/g, '')}>0</span>
              </div>
              <span class="stat-label">{s.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Logo Wall -->
  <section class="logo-wall">
    <div class="container">
      <p class="logo-wall-label">Usado por consultorios en todo México</p>
      <div class="logo-wall-grid">
        {logoWall.map(clinic => (
          <div class="clinic-logo">
            <span class="clinic-initials" style={`background: ${clinic.color}18; color: ${clinic.color};`}>
              {clinic.initials}
            </span>
            <span class="clinic-name">{clinic.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header section-reveal" data-animate>
        <span class="section-tag">Funcionalidades</span>
        <h2>Todo lo que necesitas para tu consultorio</h2>
        <p>Herramientas profesionales diseñadas para dentistas mexicanos.</p>
      </div>
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card card-glow" data-animate data-delay={String((i % 3) + 1)}>
            <div class="feature-icon">
              <i class={`fa-solid ${f.icon}`}></i>
            </div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">¿Cómo funciona?</span>
        <h2>Empieza en 3 simples pasos</h2>
        <p>Configurar tu consultorio en SmartDental Cloud es rápido y sencillo.</p>
      </div>
      <div class="steps-grid">
        {steps.map((s, i) => (
          <div class="step-card" data-animate data-delay={String(i + 1)}>
            <div class="step-number">{s.num}</div>
            <div class="step-icon">
              <i class={`fa-solid ${s.icon}`}></i>
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Journey Benefits -->
  <section class="journey" id="solutions">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">Soluciones</span>
        <h2>El software para cada etapa de tu consultorio</h2>
        <p>Herramientas pensadas para atraer pacientes, brindar experiencias memorables y hacer crecer tu negocio.</p>
      </div>
      <div class="journey-grid">
        {journeyStages.map((stage, i) => (
          <div class="journey-card" data-animate data-delay={String((i % 2) + 1)}>
            <div class="journey-icon" style={`background: ${stage.bg}; color: ${stage.color};`}>
              <i class={`fa-solid ${stage.icon}`}></i>
            </div>
            <h3>{stage.title}</h3>
            <p class="journey-desc">{stage.desc}</p>
            <ul class="journey-items">
              {stage.items.map(item => (
                <li><i class="fa-solid fa-check" style={`color: ${stage.color};`}></i> {item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Section -->
  <section class="comparison">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">Comparación</span>
        <h2>¿Por qué SmartDental Cloud?</h2>
        <p>Deja atrás el Excel y el software instalado. Así se compara con las alternativas comunes.</p>
      </div>
      <div class="comparison-wrapper" data-animate data-delay="1">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="feature-col">Característica</th>
              <th class="us-col">
                <div class="col-header col-header--us">
                  <i class="fa-solid fa-tooth"></i>
                  SmartDental Cloud
                </div>
              </th>
              <th>
                <div class="col-header">
                  <i class="fa-solid fa-file-excel"></i>
                  Excel / Papel
                </div>
              </th>
              <th>
                <div class="col-header">
                  <i class="fa-solid fa-desktop"></i>
                  Software instalado
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map(row => (
              <tr>
                <td class="feature-col">{row.feature}</td>
                <td class="us-col">
                  <i class="fa-solid fa-circle-check check-yes"></i>
                </td>
                <td>
                  {row.excel === true
                    ? <i class="fa-solid fa-circle-check check-yes"></i>
                    : row.excel === 'partial'
                    ? <i class="fa-solid fa-circle-minus check-partial"></i>
                    : <i class="fa-solid fa-circle-xmark check-no"></i>
                  }
                </td>
                <td>
                  {row.legacy === true
                    ? <i class="fa-solid fa-circle-check check-yes"></i>
                    : row.legacy === 'partial'
                    ? <i class="fa-solid fa-circle-minus check-partial"></i>
                    : <i class="fa-solid fa-circle-xmark check-no"></i>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Video Demo -->
  <section class="video-section">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">Demo</span>
        <h2>Mira SmartDental Cloud en acción</h2>
        <p>Descubre cómo simplificar la gestión de tu consultorio en minutos.</p>
      </div>
      <div class="video-wrapper" data-animate data-delay="1">
        <video controls playsinline preload="none" poster="/video-poster.jpg">
          <source src="/video-generado.mp4" type="video/mp4" />
          Tu navegador no soporta video HTML5.
        </video>
      </div>
    </div>
  </section>

  <!-- Consultorio Moderno — Full-width visual -->
  <section class="clinic-showcase">
    <Image src={clinicImg} alt="Consultorio dental moderno" class="clinic-bg" width={1400} quality={80} loading="lazy" />
    <div class="clinic-overlay">
      <div class="container clinic-content">
        <h2>Moderniza tu consultorio con tecnología de punta</h2>
        <p>Únete a los consultorios que ya dejaron el papel atrás y gestionan todo desde la nube.</p>
        <a href={`${appUrl}/register`} class="btn btn-white btn-lg">
          <i class="fa-solid fa-rocket"></i> Comenzar Ahora
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="testimonials">
    <div class="container">
      <div class="section-header section-reveal" data-animate>
        <span class="section-tag">Testimonios</span>
        <h2>Lo que dicen nuestros clientes</h2>
        <p>Consultorios de todo México confían en SmartDental Cloud para su gestión diaria.</p>
      </div>
      <div class="testimonials-grid">
        {testimonials.map((t, i) => (
          <div class="testimonial-card card-glow" data-animate data-delay={String(i + 1)}>
            <div class="testimonial-stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            <blockquote>"{t.quote}"</blockquote>
            <div class="testimonial-author">
              <Image src={t.img} alt={t.name} width={48} quality={85} class="author-img" loading="lazy" />
              <div>
                <strong>{t.name}</strong>
                <span>{t.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq" id="faq">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">FAQ</span>
        <h2>Preguntas frecuentes</h2>
        <p>Resolvemos las dudas más comunes sobre SmartDental Cloud.</p>
      </div>
      <div class="faq-grid">
        {faqs.map((item, i) => (
          <div class="faq-item" data-animate data-delay={String((i % 2) + 1)}>
            <div class="faq-icon"><i class="fa-solid fa-circle-question"></i></div>
            <div>
              <h4>{item.q}</h4>
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="faq-cta" data-animate>
        <p>¿Tienes otra pregunta?</p>
        <a href="/#contact" class="btn btn-outline">Contáctanos</a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-info" data-animate>
          <span class="section-tag">Contacto</span>
          <h2>¿Listo para empezar?</h2>
          <p>Nuestro equipo está listo para ayudarte a encontrar el plan ideal para tu consultorio. Respuesta en menos de 24 horas.</p>

          <div class="contact-channels">
            <a href="mailto:hola@smartdentalcloud.com" class="contact-channel">
              <div class="channel-icon" style="background: #dbeafe; color: #2563eb;">
                <i class="fa-solid fa-envelope"></i>
              </div>
              <div>
                <strong>Email</strong>
                <span>hola@smartdentalcloud.com</span>
              </div>
            </a>
            <a href="https://wa.me/528001234567" target="_blank" rel="noopener" class="contact-channel">
              <div class="channel-icon" style="background: #d1fae5; color: #059669;">
                <i class="fa-brands fa-whatsapp"></i>
              </div>
              <div>
                <strong>WhatsApp</strong>
                <span>+52 800 123 4567</span>
              </div>
            </a>
            <a href={`${appUrl}/register`} class="contact-channel">
              <div class="channel-icon" style="background: #ede9fe; color: #7c3aed;">
                <i class="fa-solid fa-calendar-check"></i>
              </div>
              <div>
                <strong>Agendar demo</strong>
                <span>Gratis, sin compromiso</span>
              </div>
            </a>
          </div>
        </div>

        <form class="contact-form" data-animate data-delay="1" action="mailto:hola@smartdentalcloud.com" method="post" enctype="text/plain">
          <div class="form-group">
            <label for="contact-name">Nombre</label>
            <input type="text" id="contact-name" name="nombre" placeholder="Tu nombre completo" required />
          </div>
          <div class="form-group">
            <label for="contact-email">Correo electrónico</label>
            <input type="email" id="contact-email" name="email" placeholder="tucorreo@ejemplo.com" required />
          </div>
          <div class="form-group">
            <label for="contact-clinic">Nombre del consultorio</label>
            <input type="text" id="contact-clinic" name="consultorio" placeholder="Consultorio Dental..." />
          </div>
          <div class="form-group">
            <label for="contact-msg">Mensaje</label>
            <textarea id="contact-msg" name="mensaje" rows="4" placeholder="Cuéntanos sobre tu consultorio y cómo podemos ayudarte..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
            <i class="fa-solid fa-paper-plane"></i> Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta">
    <div class="cta-bg-effects">
      <div class="cta-orb cta-orb-1"></div>
      <div class="cta-orb cta-orb-2"></div>
    </div>
    <div class="container cta-inner">
      <h2 data-animate>Empieza hoy con 14 días gratis</h2>
      <p data-animate data-delay="1">Sin tarjeta de crédito. Sin compromisos. Cancela cuando quieras.</p>
      <a href={`${appUrl}/register`} class="btn btn-white btn-lg btn-glow btn-shimmer btn-ripple" data-animate data-delay="2">
        <i class="fa-solid fa-rocket"></i> Crear Mi Consultorio
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ===== Hero ===== */
  .hero {
    padding: 60px 0 80px;
    background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 50%, #ecfdf5 100%);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    position: relative;
    z-index: 2;
  }

  .hero-content { text-align: left; position: relative; z-index: 2; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 100px;
