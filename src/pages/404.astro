---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.smartdentalcloud.com';
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe. Vuelve al inicio de SmartDental Cloud."
>
  <Header />

  <section class="not-found">
    <div class="container not-found-inner">
      <div class="error-icon">
        <i class="fa-solid fa-tooth"></i>
      </div>
      <h1>404</h1>
      <h2>Esta página no existe</h2>
      <p>
        Parece que la página que buscas se fue de vacaciones... o nunca existió.<br />
        No te preocupes, puedes volver al inicio o explorar las opciones de abajo.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-primary btn-lg">
          <i class="fa-solid fa-house"></i> Ir al Inicio
        </a>
        <a href="/pricing" class="btn btn-outline btn-lg">Ver Precios</a>
      </div>
      <div class="not-found-links">
        <p>O navega directamente a:</p>
        <div class="quick-links">
          <a href="/#features"><i class="fa-solid fa-list-check"></i> Funcionalidades</a>
          <a href="/#contact"><i class="fa-solid fa-envelope"></i> Contacto</a>
          <a href={`${appUrl}/login`}><i class="fa-solid fa-right-to-bracket"></i> Iniciar Sesión</a>
          <a href={`${appUrl}/register`}><i class="fa-solid fa-rocket"></i> Prueba Gratis</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .not-found {
    padding: 80px 0 100px;
    background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 50%, #ecfdf5 100%);
    min-height: calc(100vh - 72px - 300px);
  }

  .not-found-inner {
    text-align: center;
    max-width: 600px;
  }

  .error-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  .error-icon i {
    font-size: 36px;
    color: var(--primary);
  }

  .not-found h1 {
    font-size: 96px;
    font-weight: 900;
    line-height: 1;
    color: var(--primary);
    margin-bottom: 8px;
    letter-spacing: -4px;
  }

  .not-found h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text);
  }

  .not-found > .container > p,
  .not-found p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .not-found-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .not-found-links p {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .quick-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .quick-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    transition: all 0.2s;
  }

  .quick-links a:hover {
    border-color: var(--primary);
    color: var(--primary);
    box-shadow: var(--shadow);
  }

  .quick-links a i { font-size: 13px; }
</style>
